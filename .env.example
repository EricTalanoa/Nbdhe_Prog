# Supabase — from Project Settings → API. Copy to .env.local (never commit real keys).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key is NOT used by the app. Keep it out of .env.local entirely;
# it is only needed locally if you run migrations via the Supabase CLI.
